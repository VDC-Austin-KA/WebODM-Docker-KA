# Application Server Configuration
# Port where WebODM server will listen (default: 8000)
WO_PORT=8000

# Bind address - 0.0.0.0 means all interfaces (change for production)
WO_HOST=0.0.0.0

# Debug mode - set to 1 only for development, 0 for production
WO_DEBUG=0

# Celery/Redis broker connection URL
WO_BROKER=redis://broker:6379

# Development settings
WO_DEV=0
WO_DEV_WATCH_PLUGINS=0

# CRITICAL: Change this to a strong random value in production!
# Generate a new value with: python -c "import secrets; print(secrets.token_hex(32))"
WO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Number of web workers (adjust based on CPU cores)
WEB_CONCURRENCY=4

# Data Directory Configuration
# Directory for PostgreSQL database files
WO_DB_DIR=./data/db

# Directory for uploaded media and processed results
WO_MEDIA_DIR=./data/media
